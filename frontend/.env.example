# URL of the backend API (Express). No trailing slash.
NEXT_PUBLIC_API_BASE_URL=http://localhost:4000
# Public site URL (used for canonical URLs, sitemap, Open Graph).
NEXT_PUBLIC_SITE_URL=http://localhost:3000
# Site name shown in titles and metadata.
NEXT_PUBLIC_SITE_NAME=StoryHub
# Google Analytics Measurement ID (G-XXXXXXXXXX)
NEXT_PUBLIC_GA_ID=
